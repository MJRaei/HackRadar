# === Required ===
GOOGLE_API_KEY=your-google-api-key-here

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./hackradar.db

# === Qdrant ===
QDRANT_HOST=localhost
QDRANT_PORT=6333

# === LLM (Google ADK) ===
# Options: gemini-2.0-flash, gemini-2.5-pro, gemini-1.5-pro
LLM_MODEL=gemini-2.5-flash

# === Embedding ===
EMBEDDING_MODEL=allenai-specter

# === Storage ===
# Directory where cloned repos are stored
REPOS_BASE_DIR=./data/repos
