# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./hackradar.db

# === Qdrant ===
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ============================================================
# === LLM Provider
# ============================================================
# Choose one provider: gemini | openai | openai_compatible
LLM_PROVIDER=gemini

# --- Option A: Gemini (default) ---
# Requires GOOGLE_API_KEY
GOOGLE_API_KEY=your-google-api-key-here
LLM_MODEL=gemini-2.0-flash

# --- Option B: Standard OpenAI ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# --- Option C: OpenAI-compatible self-hosted endpoint ---
#   Example: hackathon GPT-OSS server on HuggingFace
# LLM_PROVIDER=openai_compatible
# LLM_MODEL=openai/gpt-oss-120b
# OPENAI_API_KEY=test
# OPENAI_BASE_URL=https://vjioo4r1vyvcozuj.us-east-2.aws.endpoints.huggingface.cloud/v1

# === Embedding ===
EMBEDDING_MODEL=allenai-specter

# === Storage ===
# Directory where cloned repos are stored
REPOS_BASE_DIR=./data/repos

# === Google Custom Search ===
# Required for web search during scoring (finding similar projects for novelty assessment).
GOOGLE_SEARCH_API_KEY=your-google-search-api-key
GOOGLE_SEARCH_ENGINE_ID=your-programmable-search-engine-id
